# =====================================================
# L2C — LLM to Computer · 환경변수 예시
# 실제 사용 시 .env로 복사 후 값 채우기
# =====================================================

# --- LLM / VLM ---
# 로컬 Ollama 서버 (Qwen2.5-VL)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b

# (선택) 클라우드 LLM 폴백
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Playwright ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# --- OmniParser (Agent 전용) ---
OMNIPARSER_MODEL_PATH=./models/omniparser
OMNIPARSER_DEVICE=cuda

# --- 저장소 ---
DB_PATH=./data/jobs.db
SCREENSHOT_DIR=./data/screenshots
JSON_OUTPUT_DIR=./data/json

# Ollama 모델 파라미터
LLM_TEMPERATURE=0.1
LLM_NUM_PREDICT=2048

# =====================================================
# [Phase 2] Agent 및 모니터링 환경변수
# =====================================================

# Sentry 에러 트래킹 DSN (선택사항, 발급받은 DSN 입력)
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

# 앱 환경 (development | production)
APP_ENV="development"

# --- 로깅 ---
LOG_LEVEL=INFO
LOG_DIR=./logs
