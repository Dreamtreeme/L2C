# =====================================================
# Job Extractor Evolution - 환경변수 예시
# 실제 사용 시 .env로 복사 후 값 채우기
# =====================================================

# --- LLM / VLM ---
# 로컬 Ollama 서버 (Qwen2.5-VL)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b

# (선택) 클라우드 LLM 폴백
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Playwright ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# --- OmniParser (Agent 전용) ---
OMNIPARSER_MODEL_PATH=./models/omniparser
OMNIPARSER_DEVICE=cuda

# --- 저장소 ---
DB_PATH=./data/jobs.db
SCREENSHOT_DIR=./data/screenshots
JSON_OUTPUT_DIR=./data/json

# --- 로깅 ---
LOG_LEVEL=INFO
LOG_DIR=./logs
